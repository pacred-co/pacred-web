+// ────────────────────────────────────────────────────────────────────────
+// FREEZE at the COMMIT boundary (bill live-view→freeze · 2026-07-13)
+// ────────────────────────────────────────────────────────────────────────
+//
+// Recompute a bill's subtotal / เหมาๆ / total (+ per-line amounts) over the LIVE
+// forwarder rows via the shared resolver and WRITE them onto tb_forwarder_invoice,
+// so the amount the customer commits to is captured verbatim at the moment the bill
+// leaves the amount-live state (slip-submit / offline-settle). After this the bill is
+// FROZEN — loadBillingRunDocument shows the stored columns, and a later source edit
+// surfaces via the drift banner (a real correction goes through คืนเงิน/ออกใบใหม่).
+// Best-effort: returns null on any failure so the caller keeps the stored total
+// (a freeze problem NEVER fails the money-safe commit). Idempotent — freezing an
+// already-frozen bill re-writes the same numbers.
+async function freezeBillTotals(
+  admin: ReturnType<typeof createAdminClient>,
+  invoiceId: number,
+): Promise<{ subtotal: number; maoFee: number; total: number } | null> {
+  const { data: hdr, error: hdrErr } = await admin
+    .from("tb_forwarder_invoice")
+    .select("userid, is_juristic, delivery_chn_thb, delivery_th_thb, other_thb, discount_thb, mao_fee_thb")
+    .eq("id", invoiceId)
+    .maybeSingle<{
+      userid: string | null; is_juristic: boolean;
+      delivery_chn_thb: number | string; delivery_th_thb: number | string;
+      other_thb: number | string; discount_thb: number | string;
+      mao_fee_thb: number | string | null;
+    }>();
+  if (hdrErr || !hdr) {
+    if (hdrErr) console.error("[freezeBillTotals header] failed", { code: hdrErr.code, message: hdrErr.message, invoiceId });
+    return null;
+  }
+  const { data: itemRows, error: itemErr } = await admin
+    .from("tb_forwarder_invoice_item")
+    .select("forwarder_id, amount_thb, amount_is_override")
+    .eq("invoice_id", invoiceId);
+  if (itemErr) {
+    console.error("[freezeBillTotals items] failed", { code: itemErr.code, message: itemErr.message, invoiceId });
+    return null;
+  }
+  const storedItems = (itemRows ?? []) as Array<{ forwarder_id: number; amount_thb: number | string; amount_is_override?: boolean | null }>;
+  // Manually-overridden lines (mig 0254) → the resolver's `overrides` so the FROZEN
+  // amount captured at the commit boundary is the admin's "แก้ยอดเรียกเก็บ" figure, NOT
+  // the auto GROSS (the receipt is then pinned to this total · G1 · money-review blocker).
+  const overrideByFid: Record<string, number> = {};
+  for (const r of storedItems) {
+    if (r.amount_is_override) overrideByFid[String(r.forwarder_id)] = Number(r.amount_thb);
+  }
+  const fids = storedItems.map((r) => r.forwarder_id);
+  if (fids.length === 0) return null; // nothing to reconcile
+  const { data: fwdRows, error: fwdErr } = await admin
+    .from("tb_forwarder")
+    .select(FWD_BILLING_SELECT)
+    .in("id", fids);
+  if (fwdErr) {
+    console.error("[freezeBillTotals forwarders] failed", { code: fwdErr.code, message: fwdErr.message, invoiceId });
+    return null;
+  }
+  const rows = (fwdRows ?? []) as unknown as FwdBillingRaw[];
+  if (rows.length !== fids.length) {
+    // A forwarder is missing → do not reflow on incomplete data; keep stored.
+    console.error("[freezeBillTotals] fid count mismatch — keeping stored totals", { invoiceId, want: fids.length, got: rows.length });
+    return null;
+  }
+  const resolved = resolveBillAmounts({
+    rows: rows.map((f) => ({
+      id: f.id, fshipby: f.fshipby, ftrackingchn: f.ftrackingchn,
+      ftotalprice: f.ftotalprice, ftransportprice: f.ftransportprice,
+      fpriceupdate: f.fpriceupdate, fshippingservice: f.fshippingservice,
+      pricecrate: f.pricecrate, ftransportpricechnthb: f.ftransportpricechnthb,
+      priceother: f.priceother, fdiscount: f.fdiscount,
+      fusercompany: f.fusercompany, paymethod: f.paymethod,
+    })),
+    deliveryChnThb: Number(hdr.delivery_chn_thb),
+    deliveryThThb:  Number(hdr.delivery_th_thb),
+    otherThb:       Number(hdr.other_thb),
+    discountThb:    Number(hdr.discount_thb),
+    userId:         hdr.userid ?? "",
+    isJuristic:     hdr.is_juristic,
+    // เหมาๆ + the 4 adjustments are CARRIED (header decisions · no forwarder source);
+    // only the per-line freight reflows.
+    maoFeeOverride: Number(hdr.mao_fee_thb ?? 0),
+    // a manual per-line override wins + is frozen verbatim (mig 0254).
+    overrides:      overrideByFid,
+    // preserve an unpriced line's create-guard override (don't freeze it back to ฿0).
+    preserveUnpricedFromStored: Object.fromEntries(
+      storedItems.map((r) => [String(r.forwarder_id), Number(r.amount_thb)]),
+    ),
+  });
+  if (resolved.overflow) {
+    console.error("[freezeBillTotals] resolver overflow — keeping stored totals", { invoiceId });
+    return null;
+  }
+  const { error: updErr } = await admin
+    .from("tb_forwarder_invoice")
+    .update({
+      subtotal_thb: resolved.subtotal,
+      mao_fee_thb:  resolved.maoFee,
+      total_thb:    resolved.total,
+    })
+    .eq("id", invoiceId);
+  if (updErr) {
+    console.error("[freezeBillTotals header update] failed", { code: updErr.code, message: updErr.message, invoiceId });
+    return null;
+  }
+  // Freeze the per-line amounts too (only the ones that actually changed) so Σ items
+  // == the frozen subtotal (the admin detail line table + the mig 0138 invariant stay
+  // consistent). Per-line update is non-fatal (the header total is authoritative).
+  const storedByFid = new Map(storedItems.map((r) => [r.forwarder_id, Number(r.amount_thb)]));
+  for (const [fid, amt] of resolved.perLine) {
+    if (Math.abs((storedByFid.get(fid) ?? 0) - amt) <= 0.005) continue; // unchanged → skip the write
+    const { error: liErr } = await admin
+      .from("tb_forwarder_invoice_item")
+      .update({ amount_thb: amt })
+      .eq("invoice_id", invoiceId)
+      .eq("forwarder_id", fid);
+    if (liErr) console.error("[freezeBillTotals item update] failed (non-fatal)", { code: liErr.code, message: liErr.message, invoiceId, fid });
+  }
+  return { subtotal: resolved.subtotal, maoFee: resolved.maoFee, total: resolved.total };
+}
