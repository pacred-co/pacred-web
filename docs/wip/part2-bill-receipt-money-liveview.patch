/**
 * Unit tests for lib/billing/resolve-bill-amounts.ts — the SINGLE ใบวางบิล money
 * formula shared by create + live-view + freeze. Pure, no IO.
 *
 * Proves: Σ per-line == subtotal · COD (ปลายทาง) domestic-leg exclusion · เหมาๆ
 * once-per-shipment (base-tracking anchor) · per-line override wins · header
 * adjustments · overflow guard · and that the result reconciles with computeBillWht.
 *
 * Run:  pnpm tsx lib/billing/resolve-bill-amounts.test.ts   (wired into pnpm test:unit)
 */

import { resolveBillAmounts, type ResolveBillRow, BILL_TOTAL_MAX } from "./resolve-bill-amounts";
import { calcForwarderGross } from "@/lib/forwarder/outstanding";
import { computeBillWht } from "./wht";

let pass = 0;
let fail = 0;
function assertEq<T>(label: string, actual: T, expected: T) {
  if (JSON.stringify(actual) === JSON.stringify(expected)) { pass++; console.log(`  ✓ ${label}`); }
  else { fail++; console.error(`  ✗ ${label}\n    expected: ${JSON.stringify(expected)}\n    actual:   ${JSON.stringify(actual)}`); }
}
function section(name: string) { console.log(`\n${name}`); }

/** Build a full ResolveBillRow (all fields 0/null) with overrides. */
function row(o: Partial<ResolveBillRow> & { id: number }): ResolveBillRow {
  return {
    fshipby: null, ftrackingchn: null,
    ftotalprice: 0, ftransportprice: 0, fpriceupdate: 0, fshippingservice: 0,
    pricecrate: 0, ftransportpricechnthb: 0, priceother: 0, fdiscount: 0,
    fusercompany: null, paymethod: null, ...o,
  };
}

const base = {
  deliveryChnThb: 0, deliveryThThb: 0, otherThb: 0, discountThb: 0,
  userId: "PR001", isJuristic: false,
};

// ────────────────────────────────────────────────────────────────────────
section("subtotal = Σ per-line gross");

{
  const r = resolveBillAmounts({
    ...base,
    rows: [
      row({ id: 1, ftotalprice: 1000, ftransportprice: 100 }),
      row({ id: 2, ftotalprice: 500, fpriceupdate: 25, fdiscount: 15 }),
    ],
  });
  assertEq("line 1 = 1100", r.perLine.get(1), 1100);
  assertEq("line 2 = 510", r.perLine.get(2), 510);
  assertEq("subtotal = Σ lines (1610)", r.subtotal, 1610);
  assertEq("total = subtotal (no mao, no adj)", r.total, 1610);
  assertEq("Σ perLine === subtotal", r.perLine.get(1)! + r.perLine.get(2)!, r.subtotal);
}

// ────────────────────────────────────────────────────────────────────────
section("COD (ปลายทาง · paymethod='2') excludes the domestic leg");

{
  const prepaid = resolveBillAmounts({ ...base, rows: [row({ id: 1, ftotalprice: 1000, ftransportprice: 100, paymethod: "1" })] });
  const cod     = resolveBillAmounts({ ...base, rows: [row({ id: 1, ftotalprice: 1000, ftransportprice: 100, paymethod: "2" })] });
  assertEq("prepaid → domestic leg INCLUDED (1100)", prepaid.total, 1100);
  assertEq("COD → domestic leg EXCLUDED (1000)", cod.total, 1000);
  // resolver line agrees with calcForwarderGross directly (single SOT).
  assertEq("resolver line == calcForwarderGross (COD)",
    cod.perLine.get(1), calcForwarderGross(row({ id: 1, ftotalprice: 1000, ftransportprice: 100, paymethod: "2" })));
}

// ────────────────────────────────────────────────────────────────────────
section("เหมาๆ once-per-shipment (base-tracking anchor · PCSF/PRF flat ฿100)");

{
  // Two box-split siblings of ONE shipment (base tracking SF001, box SF001-1/-2),
  // both เหมาๆ (PRF · ftransportprice 0). The ฿100 fee is charged ONCE (on the base).
  const r = resolveBillAmounts({
    ...base,
    rows: [
      row({ id: 1, fshipby: "PRF", ftrackingchn: "SF001",   ftotalprice: 300 }),
      row({ id: 2, fshipby: "PRF", ftrackingchn: "SF001-1", ftotalprice: 200 }),
      row({ id: 3, fshipby: "PRF", ftrackingchn: "SF001-2", ftotalprice: 100 }),
    ],
  });
  assertEq("subtotal = Σ freight (600 · mao is a SEPARATE line)", r.subtotal, 600);
  assertEq("เหมาๆ = ฿100 ONCE (not ฿300)", r.maoFee, 100);
  assertEq("total = subtotal + mao (700)", r.total, 700);
}

{
  // maoFeeOverride wins even at 0 (admin waived เหมาๆ · live-view carries the header value).
  const r = resolveBillAmounts({
    ...base,
    rows: [row({ id: 1, fshipby: "PRF", ftrackingchn: "SF001", ftotalprice: 300 })],
    maoFeeOverride: 0,
  });
  assertEq("maoFeeOverride 0 wins over the ฿100 auto", r.maoFee, 0);
  assertEq("total = subtotal only when mao waived", r.total, 300);
}

{
  // A non-เหมาๆ carrier gets no flat fee.
  const r = resolveBillAmounts({ ...base, rows: [row({ id: 1, fshipby: "PCS", ftotalprice: 300 })] });
  assertEq("non-PCSF carrier → เหมาๆ 0", r.maoFee, 0);
}

// ────────────────────────────────────────────────────────────────────────
section("per-line override wins over the auto gross");

{
  const r = resolveBillAmounts({
    ...base,
    rows: [
      row({ id: 1, ftotalprice: 1000 }),
      row({ id: 2, ftotalprice: 500 }),
    ],
    overrides: { "1": 850 },
  });
  assertEq("line 1 = override (850)", r.perLine.get(1), 850);
  assertEq("line 2 = auto gross (500)", r.perLine.get(2), 500);
  assertEq("subtotal reflects the override (1350)", r.subtotal, 1350);
}

{
  // Non-finite / out-of-map override keys ignored (no NaN leak).
  const r = resolveBillAmounts({
    ...base,
    rows: [row({ id: 1, ftotalprice: 1000 })],
    overrides: { "1": Number.NaN, "999": 5 },
  });
  assertEq("NaN override ignored → auto gross", r.perLine.get(1), 1000);
  assertEq("subtotal = 1000 (stray key 999 ignored)", r.subtotal, 1000);
}

// ────────────────────────────────────────────────────────────────────────
section("reflow preservation floor (unpriced line keeps its stored override)");

{
  // A ฿0-transport row the create-guard REQUIRED a positive override for (stored 850).
  // On a live-view reflow (no override passed) its GROSS is still 0 → KEEP the stored 850
  // (never silently under-charge back to ฿0). A priced line reflows normally.
  const r = resolveBillAmounts({
    ...base,
    rows: [
      row({ id: 1, ftotalprice: 0 }),    // unpriced → gross 0
      row({ id: 2, ftotalprice: 1200 }), // priced → gross 1200 (reflows in both directions)
    ],
    preserveUnpricedFromStored: { "1": 850, "2": 1000 },
  });
  assertEq("unpriced line 1 keeps stored 850 (not ฿0)", r.perLine.get(1), 850);
  assertEq("priced line 2 reflows to live gross 1200 (stored 1000 ignored)", r.perLine.get(2), 1200);
  assertEq("subtotal = 850 + 1200", r.subtotal, 2050);
}

{
  // An explicit override ALWAYS wins over the preservation floor.
  const r = resolveBillAmounts({
    ...base,
    rows: [row({ id: 1, ftotalprice: 0 })],
    overrides: { "1": 300 },
    preserveUnpricedFromStored: { "1": 850 },
  });
  assertEq("override wins over the stored-preserve floor", r.perLine.get(1), 300);
}

{
  // MONEY-REVIEW BLOCKER (mig 0254) — a PRICED line the admin manually overrode BELOW
  // its auto gross must NOT reflow to gross on an amount-live reload / freeze. The
  // caller (loader/list/freeze) reconstructs `overrides` from the persisted
  // amount_is_override flag AND still passes preserveUnpricedFromStored (both maps
  // present, as in the real caller). The override must win → the customer is billed the
  // ฿500 the admin typed, never the ฿800 gross.
  const r = resolveBillAmounts({
    ...base,
    rows: [row({ id: 1, ftotalprice: 800 })], // live gross 800
    overrides: { "1": 500 },                  // admin typed 500 (persisted override)
    preserveUnpricedFromStored: { "1": 500 }, // stored amount also seen by the caller
  });
  assertEq("priced override 500 held (not reflowed to gross 800)", r.perLine.get(1), 500);
  assertEq("subtotal honors the override (500)", r.subtotal, 500);
  // Direction-symmetric: an override ABOVE gross must not silently under-collect either.
  const r2 = resolveBillAmounts({
    ...base,
    rows: [row({ id: 1, ftotalprice: 800 })],
    overrides: { "1": 1200 },
    preserveUnpricedFromStored: { "1": 1200 },
  });
  assertEq("priced override 1200 held (above gross 800)", r2.perLine.get(1), 1200);
}

{
  // Absent preservation map (create path) → an unpriced line is ฿0 (unchanged behavior).
  const r = resolveBillAmounts({ ...base, rows: [row({ id: 1, ftotalprice: 0 })] });
  assertEq("no preserve map → unpriced line = 0", r.perLine.get(1), 0);
}

// ────────────────────────────────────────────────────────────────────────
section("header adjustments (chn/th/other − discount) + never-negative total");

{
  const r = resolveBillAmounts({
    ...base,
    rows: [row({ id: 1, ftotalprice: 1000 })],
    deliveryChnThb: 50, deliveryThThb: 30, otherThb: 20, discountThb: 10,
  });
  assertEq("total = 1000 + 50 + 30 + 20 − 10 = 1090", r.total, 1090);
}

{
  // discount larger than everything → total clamps to 0 (never negative).
  const r = resolveBillAmounts({ ...base, rows: [row({ id: 1, ftotalprice: 100 })], discountThb: 500 });
  assertEq("over-discount clamps total to 0", r.total, 0);
}

// ────────────────────────────────────────────────────────────────────────
section("satang quantization — subtotal == Σ quantized lines to the satang");

{
  // Legacy varchar decimals; each line rounds to 2dp BEFORE summing (mig 0138 invariant).
  const r = resolveBillAmounts({
    ...base,
    rows: [
      row({ id: 1, ftotalprice: "1000.005" }), // → 1000.01 (round-half-up on .005 → JS Math.round)
      row({ id: 2, ftotalprice: "0.334" }),    // → 0.33
    ],
  });
  const l1 = r.perLine.get(1)!;
  const l2 = r.perLine.get(2)!;
  assertEq("subtotal == l1 + l2 to the satang", r.subtotal, Math.round((l1 + l2) * 100) / 100);
}

// ────────────────────────────────────────────────────────────────────────
section("overflow guard (NUMERIC(12,2) ceiling)");

{
  const under = resolveBillAmounts({ ...base, rows: [row({ id: 1, ftotalprice: BILL_TOTAL_MAX })] });
  assertEq("at the ceiling → not overflow", under.overflow, false);
  const over = resolveBillAmounts({ ...base, rows: [row({ id: 1, ftotalprice: BILL_TOTAL_MAX }), row({ id: 2, ftotalprice: 1 })] });
  assertEq("over the ceiling → overflow", over.overflow, true);
}

// ────────────────────────────────────────────────────────────────────────
section("reconciles with computeBillWht (bill face → 1% once → net)");

{
  // Juristic ฿5,000 gross → the WHT is a DISPLAY line on top of the resolver total.
  const r = resolveBillAmounts({ ...base, isJuristic: true, rows: [row({ id: 1, ftotalprice: 5000 })] });
  const w = computeBillWht(true, r.total);
  assertEq("total = gross 5000 (WHT is a header line, not in subtotal)", r.total, 5000);
  assertEq("WHT 1% = 50 · net 4950", [w.wht_amount, w.net_payable], [50, 4950]);
  assertEq("wht + net === total (satang)", Math.round((w.wht_amount + w.net_payable) * 100) / 100, r.total);
}

console.log(`\n${fail === 0 ? "✅" : "❌"} billing/resolve-bill-amounts: ${pass} pass / ${fail} fail`);
if (fail > 0) process.exit(1);
