/**
 * resolve-bill-amounts.ts — the SINGLE, pure formula for a ใบวางบิล's money.
 *
 * ── WHY THIS EXISTS (bill live-view→freeze · 2026-07-13) ────────────────────
 * The ใบวางบิล's subtotal / เหมาๆ / total were computed inline in THREE places:
 *   1. createBillingRunInvoiceImpl        (at issue · billing-run.ts ~1485-1549)
 *   2. the loader's live-view reflow      (an amount-live bill · load-billing-run-document.ts)
 *   3. the commit-boundary freeze          (slip-submit / offline-settle · billing-run.ts)
 * Three copies drift. This module is the ONE formula they all call so the create
 * total, the live-view total, the frozen total, the list total and the /b/[token]
 * QR net all reconcile TO THE SATANG by construction (guardrail b).
 *
 * It is EXTRACTED verbatim from the create math (billing-run.ts:1485-1544):
 *   perLine(id)  = round2( overrides[id] ?? calcForwarderGross(liveRow) )   (1519-1523)
 *   subtotal     = Σ perLine                                                 (1525)
 *   mao          = maoFeeOverride ?? Σ computeForwarderDebitBatch(rows).maoFee (1497-1535)
 *   total        = max(0, subtotal + mao + chn + th + other − discount)      (1536-1539)
 *   overflow     = subtotal > 9,999,999,999.99 || total > …                  (1544)
 *
 * PURE — no IO, no Supabase. calcForwarderGross already excludes a COD (ปลายทาง ·
 * paymethod='2') domestic leg (outstanding.ts) and computeForwarderDebitBatch
 * charges เหมาๆ ONCE per shipment (base-tracking anchor · forwarder-debit-total.ts),
 * so both money rules flow through this resolver for free (guardrails d + e).
 *
 * Callers:
 *   - create   → pass the create-form overrides + maoFeeOverride (byte-identical to the old inline math).
 *   - live-view → pass overrides:undefined (recompute every line from live gross) + maoFeeOverride = the
 *                 bill's stored mao_fee_thb (a header promo fee the admin set at issue — no forwarder source,
 *                 so it is CARRIED, not re-derived; the per-line freight is what reflows on a dim/rate edit).
 *   - freeze   → same inputs as live-view (freeze writes exactly what live-view showed).
 */

import { calcForwarderGross } from "@/lib/forwarder/outstanding";
import { computeForwarderDebitBatch } from "@/lib/forwarder/forwarder-debit-total";

/** A live tb_forwarder row the resolver reads (all 8 price cols + the mao + COD signals). */
export interface ResolveBillRow {
  id: number;
  /** เหมาๆ (PCSF/PRF) carrier — computeForwarderDebitBatch anchors the flat fee. */
  fshipby: string | null;
  /** Base-tracking anchor for the once-per-shipment เหมาๆ fee (optional · falls back to first-in-batch). */
  ftrackingchn?: string | null;
  ftotalprice: number | string | null;
  ftransportprice: number | string | null;
  fpriceupdate: number | string | null;
  fshippingservice: number | string | null;
  pricecrate: number | string | null;
  ftransportpricechnthb: number | string | null;
  priceother: number | string | null;
  fdiscount: number | string | null;
  /** '1'=juristic — unused by the GROSS math (kept so a row is a full ForwarderPriceFields). */
  fusercompany: number | string | null;
  /** '1'=ต้นทาง (prepaid) · '2'=ปลายทาง (COD) — a COD domestic leg is excluded from the bill face. */
  paymethod?: number | string | null;
}

export interface ResolveBillInput {
  /** The live forwarder rows the bill covers (already the exact billable set · deduped). */
  rows: ResolveBillRow[];
  /** Header adjustments — admin-typed, NO forwarder source (carried verbatim). */
  deliveryChnThb: number;
  deliveryThThb: number;
  otherThb: number;
  discountThb: number;
  /** For the เหมาๆ once-per-shipment gate (PCS999 exempt) + the corporate ≥฿1000 branch. */
  userId: string;
  isJuristic: boolean;
  /** Per-line override (forwarder_id → ฿amount, keyed as a string). A finite number wins over the auto
   *  GROSS for that line. Absent (live-view / freeze) → every line = calcForwarderGross(row). */
  overrides?: Record<string, number | null | undefined>;
  /** Header เหมาๆ override. A finite number wins; undefined → derive once-per-shipment via the batch engine. */
  maoFeeOverride?: number;
  /**
   * live-view / freeze REFLOW protection (bill live-view→freeze · 2026-07-13). The bill's
   * STORED per-line amounts (forwarder_id → ฿). When a line's live GROSS is ≤ 0 (unpriced /
   * unmeasured) but its stored amount is > 0, the STORED amount is KEPT — this preserves the
   * positive override the create-time `zeroTransport` guard REQUIRES for a ฿0-transport row
   * (a source still at ฿0 must not silently under-charge back to ฿0 on a reflow). A PRICED
   * line (gross > 0) reflows in BOTH directions. Only consulted when there is NO per-line
   * override for that row (an override always wins). Absent (create) → no preservation.
   */
  preserveUnpricedFromStored?: Record<string, number | null | undefined>;
}

export interface ResolvedBillAmounts {
  /** Σ per-line (override ?? gross), satang-quantized. */
  subtotal: number;
  /** ค่าส่งเหมาๆ (override wins · else the once-per-shipment auto Σ). */
  maoFee: number;
  /** max(0, subtotal + mao + chn + th + other − discount), satang-quantized. */
  total: number;
  /** forwarder_id → the satang-quantized line amount (create builds items · loader sets item amounts). */
  perLine: Map<number, number>;
  /** subtotal or total exceeds the NUMERIC(12,2) header ceiling → the caller must refuse. */
  overflow: boolean;
}

/** The NUMERIC(12,2) header ceiling the create form enforces (billing-run.ts:1544). */
export const BILL_TOTAL_MAX = 9_999_999_999.99;

function round2(n: number): number {
  return Math.round(n * 100) / 100;
}

/**
 * Compute a ใบวางบิล's subtotal / เหมาๆ / total + per-line amounts from LIVE forwarder
 * rows + the header adjustments. The one formula shared by create + live-view + freeze.
 */
export function resolveBillAmounts(input: ResolveBillInput): ResolvedBillAmounts {
  // ── per-line: override wins, else the GROSS composite (Σ 7 cols − discount, COD-aware) ──
  const overrideAmt = (id: number): number | null => {
    const raw = input.overrides?.[String(id)];
    return typeof raw === "number" && Number.isFinite(raw) ? raw : null;
  };
  const storedAmt = (id: number): number | null => {
    const raw = input.preserveUnpricedFromStored?.[String(id)];
    return typeof raw === "number" && Number.isFinite(raw) ? raw : null;
  };
  const perLine = new Map<number, number>();
  let subtotalRaw = 0;
  for (const r of input.rows) {
    const ov = overrideAmt(r.id);
    let amt: number;
    if (ov != null) {
      amt = round2(ov); // an explicit override always wins
    } else {
      const gross = round2(calcForwarderGross(r));
      // Reflow protection: an unpriced (gross ≤ 0) line keeps its positive stored amount
      // (the create-guard override) — never silently under-charge back to ฿0.
      const stored = storedAmt(r.id);
      amt = gross <= 0 && stored != null && stored > 0 ? round2(stored) : gross;
    }
    perLine.set(r.id, amt);
    subtotalRaw += amt;
  }
  const subtotal = round2(subtotalRaw);

  // ── เหมาๆ (PCSF/PRF flat) — once-per-shipment (base-tracking anchor). Override wins. ──
  const maoBatch = computeForwarderDebitBatch(
    input.rows.map((r) => ({
      id: r.id, fshipby: r.fshipby, ftrackingchn: r.ftrackingchn,
      ftotalprice: r.ftotalprice, ftransportprice: r.ftransportprice,
      fpriceupdate: r.fpriceupdate, fshippingservice: r.fshippingservice,
      pricecrate: r.pricecrate, ftransportpricechnthb: r.ftransportpricechnthb,
      priceother: r.priceother, fdiscount: r.fdiscount,
    })),
    { userId: input.userId, isCorporate: input.isJuristic },
  );
  const autoMaoFee = round2(
    maoBatch.lines.reduce((s, l) => s + l.breakdown.maoFee, 0),
  );
  const maoFee =
    input.maoFeeOverride != null && Number.isFinite(input.maoFeeOverride)
      ? round2(input.maoFeeOverride)
      : autoMaoFee;

  // ── total: subtotal + mao + the 4 header adjustments (never negative) ──
  const total = round2(
    Math.max(
      0,
      subtotal + maoFee + input.deliveryChnThb + input.deliveryThThb + input.otherThb - input.discountThb,
    ),
  );

  return {
    subtotal,
    maoFee,
    total,
    perLine,
    overflow: subtotal > BILL_TOTAL_MAX || total > BILL_TOTAL_MAX,
  };
}
