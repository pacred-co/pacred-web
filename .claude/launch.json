{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "pacred-1to1",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--dns-result-order=ipv4first",
        "node_modules/next/dist/bin/next",
        "dev"
      ],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "pacred-web-prod",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "node_modules/next/dist/bin/next",
        "start"
      ],
      "port": 3000
    },
    {
      "name": "pacred-main-prod",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "/Users/dev/pacred-web/node_modules/next/dist/bin/next",
        "start",
        "/Users/dev/pacred-web"
      ],
      "port": 3000
    }
  ]
}
