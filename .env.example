# ════════════════════════════════════════════════════════════════
# Pacred — Environment Variables Template
# ════════════════════════════════════════════════════════════════
# 1. Copy this file to .env.local (gitignored)
# 2. Fill in real values for the env you're running (dev/staging/prod)
# 3. NEVER commit .env.local or .env.production
#
# Canonical reference: docs/env.md
# Production-readiness checklist: docs/PORT_PLAN.md Part N9
# ════════════════════════════════════════════════════════════════


# ── 🟢 SUPABASE (required — auth + DB + storage) ─────────────────
# https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # server-only, NEVER expose to client


# ── 🟢 SITE URL (required — OAuth redirects + notification deep-links) ──
# dev: http://localhost:3000
# prod: https://pacred.co
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# ── 🟢 OTP — phone verification ──────────────────────────────────
# Set OTP_BYPASS=true in dev to skip SMS + accept any code
# Set OTP_BYPASS=false in production
OTP_BYPASS=true
OTP_PEPPER=<random-32-char-string>   # any random string, must match across deploys


# ── 🟢 SMS GATEWAY — ThaiBulkSMS (required if OTP_BYPASS=false) ──
# https://www.thaibulksms.com → Dashboard → API Settings
SMS_PROVIDER=thaibulksms
THAIBULKSMS_API_KEY=<real-api-key>
THAIBULKSMS_API_SECRET=<real-api-secret>
THAIBULKSMS_SENDER=Pacred


# ── 🟡 CHINA PRODUCT SEARCH — RCGroup + Tamit ────────────────────
# Powers /service-order/add URL→cart converter + keyword search
# Without these: URL paste returns demo product (price 0), search broken
# Legacy PHP used these endpoints — verify still alive before launch
PACRED_RCGROUP_API_URL=https://rcgroup-th.com/api-china/api-search
PACRED_TAMIT_API_URL=https://tamit-cloud.com/api-product/api-search


# ── 🟡 PROMPTPAY — wallet deposit QR ─────────────────────────────
# Pacred company phone or tax-ID (no dashes)
# Without this: /wallet/deposit QR generation throws error
PROMPTPAY_ID=<phone-or-tax-id>


# ── 🟡 LINE MESSAGING API — push notifications (replaces LINE Notify EOL) ──
# https://developers.line.biz → Messaging API channel → Channel access token
# LINE_PUSH_BYPASS=true → only console.log, never send (safe default)
# LINE_PUSH_BYPASS=false → actually push (requires token + linked user)
LINE_PUSH_BYPASS=true
LINE_CHANNEL_ACCESS_TOKEN=<from-line-developer-console>


# ── 🟡 EMAIL FALLBACK — Resend ───────────────────────────────────
# https://resend.com → API Keys
# Used when LINE push fails or user prefers email
RESEND_API_KEY=<re_xxx>
RESEND_FROM=Pacred <noreply@pacred.co>


# ── 🟡 CRON SECURITY ─────────────────────────────────────────────
# Generate: openssl rand -hex 32
# Vercel cron sends x-vercel-cron header, we also check Bearer ${CRON_SECRET}
CRON_SECRET=<random-hex-string>


# ── 🟡 YUAN RATE (optional fallback) ─────────────────────────────
# If unset, code reads from settings table (preferred)
# This is only a hard-coded fallback for dev when DB is empty
NEXT_PUBLIC_YUAN_RATE=5.00


# ── ⚪ LINE LOGIN (optional — not yet implemented) ───────────────
# When LINE OAuth is built, set these from LINE Developers Console
# LINE_LOGIN_CLIENT_ID=
# LINE_LOGIN_CLIENT_SECRET=


# ── 🟡 SENTRY — error tracking (D-11) ───────────────────────────
# https://sentry.io → Settings → Projects → <project> → Client Keys (DSN)
# All vars optional — when SENTRY_DSN is unset, Sentry SDK is no-op.
# Server + client need separate DSN env vars (NEXT_PUBLIC_ for browser).
# Same DSN value, but Next 16 requires NEXT_PUBLIC_ prefix to inline into client bundle.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ENV=production               # override of NODE_ENV for the env tag
# NEXT_PUBLIC_SENTRY_ENV=production
# Source map upload (optional — improves prod stack traces)
# Get auth token from https://sentry.io → Settings → Auth Tokens (org-level, project:write scope)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=pacred
# SENTRY_PROJECT=pacred-web
