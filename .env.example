# ════════════════════════════════════════════════════════════════
# Pacred — Environment Variables Template
# ════════════════════════════════════════════════════════════════
# 1. Copy this file to .env.local (gitignored)
# 2. Fill in real values for the env you're running (dev/staging/prod)
# 3. NEVER commit .env.local or .env.production
#
# Canonical reference: docs/env.md
# Production-readiness checklist: docs/PORT_PLAN.md Part N9
# ════════════════════════════════════════════════════════════════


# ── 🟢 SUPABASE (required — auth + DB + storage) ─────────────────
# https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # server-only, NEVER expose to client


# ── 🟢 SITE URL (required — OAuth redirects + notification deep-links) ──
# dev: http://localhost:3000
# prod: https://pacred.co
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# ── ⚪ LEGACY MEMBER IMAGE BASE — Phase A mirror of pcsracgo/public/member ──
# Override the base URL the `legacyMemberUrl()` helper (lib/legacy-image.ts)
# uses to serve customer-uploaded files (user pics / slips / shop covers /
# forwarder icons) that ภูม mirrored from pcscargo.co.th into Supabase
# Storage on 2026-05-24. If unset, the helper composes:
#   ${NEXT_PUBLIC_SUPABASE_URL}/storage/v1/object/public/pcsracgo/public/member
# Set this only if the bucket / folder layout changes or for a staging override.
# NEXT_PUBLIC_LEGACY_MEMBER_BASE=


# ── ⚪ SOCIAL LOGIN — Google / Facebook / LINE buttons on /login ──
# Single flag gating ALL social sign-in. Default (unset, or anything ≠ "true")
# → the three providers render greyed-out under a COMING SOON badge and the
# signInWithOAuth server action refuses. Set "true" to enable.
# Legacy PCS had password-only login; the D1 faithful port keeps social login
# off until Phase C. Build-time inlined (NEXT_PUBLIC_) → redeploy to flip.
NEXT_PUBLIC_SOCIAL_LOGIN_ENABLED=false


# ── 🟢 OTP — phone verification ──────────────────────────────────
# OTP_BYPASS=true  → skip the real SMS send + accept ANY OTP code.
#                    For local dev / Vercel preview ONLY (don't burn credit).
# 🚨 PRODUCTION MUST SET OTP_BYPASS=false (or leave it unset). Left "true"
#    on prod, registration shows success but no OTP SMS is sent and verify
#    accepts any code. Safety net: the code also hard-disables bypass when
#    VERCEL_ENV=production — see isSmsBypassed() in lib/sms/gateway.ts.
OTP_BYPASS=true
#
# EMERGENCY_OTP_BYPASS — env-gated emergency override, DEFAULT FALSE.
# Was hardcoded `true` in actions/otp.ts 2026-05-22 (broken SMS gateway); now
# env-controlled + off-by-default (fail-closed) per the 2026-05-30 security audit.
# 🚨 PRODUCTION MUST LEAVE THIS UNSET (or =false) so OTP is actually verified.
# Set =true ONLY for a real emergency (SMS provider down + signups blocked) — and
# remember turning it back OFF needs a working THAIBULKSMS_API_KEY below to send
# real OTPs again. Distinct from OTP_BYPASS above (the dev/preview convenience).
EMERGENCY_OTP_BYPASS=false
OTP_PEPPER=<random-32-char-string>   # any random string, must match across deploys
# OTP_PEPPER_NEXT=                    # set during the dual-pepper rotation window
# (see docs/runbook/otp-pepper-rotation.md). Verify accepts both; new mints use
# OTP_PEPPER only. Remove after the cutover.


# ── 🟢 SMS GATEWAY — ThaiBulkSMS (required if OTP_BYPASS=false) ──
# https://www.thaibulksms.com → Dashboard → API Settings
SMS_PROVIDER=thaibulksms
THAIBULKSMS_API_KEY=<real-api-key>
THAIBULKSMS_API_SECRET=<real-api-secret>
THAIBULKSMS_SENDER=Pacred
# Credit-pool router. ThaiBulkSMS v2 has separate Standard / Premium / Corporate
# credit pools — the v2 /sms endpoint defaults to Standard when this is unset.
# Pacred's "Pacred" sender ID lives in the Corporate (Premium) pool, so prod
# defaults to "premium" in code. Override here to route via a different pool.
# Values: premium | standard | corporate
THAIBULKSMS_FORCE=premium
# SMS balance threshold for U1-2 cron alert (default 100 messages).
# Cron at /api/cron/sms-balance-check pings ThaiBulkSMS daily; if remaining
# credit < threshold, notifies admins opted-in via notify_channels.sms_balance_alert.
SMS_LOW_THRESHOLD=100


# ── 🟡 CHINA PRODUCT SEARCH — TAMIT + AkuCargo + Laonet (P-50 audit) ──
# Powers /service-order/add URL→cart converter + keyword search + image search
# Without these: URL paste returns demo product (price 0), search broken
#
# ⚠️ Per docs/audit/php-pcscargo-integrations.md: legacy PHP uses TAMIT for
# product detail (NOT RCGroup — RCGroup branch is dead code). Pacred lib/
# china-search/index.ts currently wired to RCGroup is BROKEN — see P-50 in
# PORT_PLAN Sprint 7+ Track G for the rewire spec
#
# Product detail (active in PHP):  https://tamit-cloud.com/api-product/get/{1688|taobao}/?id={productID}
# Short-URL cache:                 https://tam-i-t.com/api/convert-link-china/{get,save}/[/taobao]/?tk={tk}
# Keyword search:                  https://akucargo.com/api3/api-2022/search/v1/[/taobao]/?q={words}&page={N}&page_size=15&lang=zh-CN
# Image search:                    https://laonet.online/index.php?route=api_tester/call&api_name=item_search_img&imgid={url}&key=tam011plus@gmail.com
# Image upload (returns imgid):    https://laonet.online/index.php?route=api_tester/call&api_name=upload_img&imgcode={base64}&key=tam011plus@gmail.com
#
# All endpoints unauthenticated. Pacred .env.local should set the BASE URLs
# only; per-endpoint paths are constructed in lib/china-search/<adapter>.ts
#
# ⚠️ 2026-05-27: TAMIT upstream bumped `/api-product` → `/api-product-2026`.
#    The old `/api-product` path returns 404 NOT FOUND on every request.
#    If you cloned/copied from an older .env.local, UPDATE this value or
#    remove the line entirely (lib/china-search/index.ts L48 default is correct).
#    Verified live: old=404, new=200.  Wave 24 #186 / Wave 31 ภูม flag 2026-06-02.
PACRED_TAMIT_DETAIL_URL=https://tamit-cloud.com/api-product-2026
PACRED_TAMIT_CACHE_URL=https://tam-i-t.com/api/convert-link-china
PACRED_AKUCARGO_API_URL=https://akucargo.com/api3/api-2022
PACRED_LAONET_API_URL=https://laonet.online
PACRED_LAONET_KEY=tam011plus@gmail.com
# DEAD — kept for back-compat reference; remove once lib/china-search rewired
# PACRED_RCGROUP_API_URL=https://rcgroup-th.com/api-china/api-search
# PACRED_TAMIT_API_URL=https://tamit-cloud.com/api-product/api-search

# ── 🟡 CARGOTHAI partner — container/manifest sync (D1 Gap #4) ───
# Legacy `test-api/update-data-cargothai/index.php` hits CargoThai's
# `https://cargothai.tech/api/service/GetContainerV2` with `?_token=<TOKEN>`.
# Token is requested from CargoThai ops (the legacy used the value
# `c804c3a15ebe05b5baf40ad5ee12be` — DO NOT commit; request a fresh one).
# When unset, the /admin/cargothai page renders with a "ขอ token" banner
# + the Sync-now button is disabled. Cron at /api/cron/cargothai-sync
# logs a 'failure' with reason='not_configured' until set.
# PACRED_CARGOTHAI_BASE_URL=https://cargothai.tech/api/service
PACRED_CARGOTHAI_TOKEN=


# ── 🟡 GOOGLE SHEETS sync — warehouse intake (D1 Gap #1) ─────────
# Legacy PCS Cargo pulled rows from 4 Google Sheets (CTT / MX / MK /
# Sang warehouses) every hour, INSERTed new rows into tb_forwarder, +
# fired a notification to ops. Per docs/audit/php-pcscargo-integrations.md
# §8 + d1-deep-audit-2026-05-24 Gap #1.
#
# Auth: a Google Cloud service account JSON (scope
# `spreadsheets.readonly`). PASTE THE WHOLE JSON in one line — the
# helper auto-restores newlines in the PEM key. Until set, the cron
# /api/cron/sheets-sync-ctt logs 'failure' with reason='not_configured'.
#
# ก๊อต provisions: a NEW Pacred Google Cloud project + service account
# (do NOT reuse the legacy `cryptic-album-325611-...json`) + share each
# sheet with the service account email.
#
# Sheet IDs: per-installation. The legacy CTT/MX/MK/Sang are tabs of
# `15g49hwP8dx1bOVbVKcp1V33I_o1gSLJYeqEIdRS4Mpk` (the original PCS
# Cargo sheet — Pacred owns its own copy after handoff).
# Range default: `<TabName>!A2:AZ` (skip header).
# GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_SHEETS_CTT_ID=
# GOOGLE_SHEETS_CTT_RANGE=CTT-New!A2:AZ
# GOOGLE_SHEETS_MX_ID=
# GOOGLE_SHEETS_MX_RANGE=MX!A2:AZ
# GOOGLE_SHEETS_MK_ID=
# GOOGLE_SHEETS_MK_RANGE=MK!A2:AZ
# GOOGLE_SHEETS_SANG_ID=
# GOOGLE_SHEETS_SANG_RANGE=sangNew!A2:AZ


# ── 🟡 PROMPTPAY — wallet deposit QR ─────────────────────────────
# Pacred company phone or tax-ID (no dashes)
# Without this: /wallet/deposit QR generation throws error
PROMPTPAY_ID=<phone-or-tax-id>


# ── 🟡 LINE MESSAGING API + LIFF — D-1-LIFF customer linkage + push ──
# https://developers.line.biz → Pacred Messaging API channel
# LINE_PUSH_BYPASS=true → only console.log, never send (safe default for dev)
# LINE_PUSH_BYPASS=false → actually push (requires token + linked user)
#
# Pacred OA channel — values stored in .env.local (set 2026-05-14)
# Channel ID + Secret: needed for webhook signature verification (future LINE OA bot)
# Long-lived Channel access token: from LINE Console → Messaging API → "Issue" long-lived token
#
# LIFF (D-1-LIFF) — customer link page at /liff/link populates profiles.line_user_id:
# Get LIFF ID from LINE Console → Messaging API channel → LIFF tab → Add LIFF app
# (Endpoint URL = https://pacred.co/liff/link · Size = Compact · BOT link = ON)
LINE_PUSH_BYPASS=true
# ── 🟡 NOTIFY_BYPASS — unified admin-test guard (2026-05-28 B-1) ──
# Set NOTIFY_BYPASS=true in `.env.local` when admin staff are click-testing
# mutations in `/admin/*` — short-circuits ALL THREE notification channels:
#   - SMS (lib/sms/gateway.ts isSmsBypassed)
#   - LINE push (lib/notifications/index.ts LINE_BYPASS)
#   - Email (lib/notifications/index.ts sendEmail)
# Each channel logs "would send" with redacted target so QA can verify the
# action FIRED without spamming real customer phones/inboxes.
#
# HARD-DISABLED on Vercel production (VERCEL_ENV=production) regardless of
# this value — same defence-in-depth as OTP_BYPASS. Local dev + Vercel
# preview honor the flag.
#
# Default: unset / false → real sends happen (subject to LINE_PUSH_BYPASS
# + RESEND_API_KEY + THAIBULKSMS_API_KEY being configured).
# NOTIFY_BYPASS=false
#
# ── 🟢 LINE OA inbound webhook — POST /api/webhooks/line (2026-05-29) ──
# รับข้อความลูกค้าจาก LINE OA → เก็บลง customers_line / line_messages /
# line_webhook_events (migration 0125). ไม่ต้องเพิ่ม env ใหม่ — ใช้ของเดิม:
#   • LINE_CHANNEL_SECRET        (REQUIRED) verify ลายเซ็น x-line-signature
#                                 ของทุก request. ไม่ตั้ง = route คืน 503.
#   • LINE_CHANNEL_ACCESS_TOKEN  (OPTIONAL) ถ้าตั้ง → ดึง display_name +
#                                 picture_url ของลูกค้า (best-effort · ไม่ตั้ง
#                                 ก็ยังเก็บข้อความได้ครบ).
#   • NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY — มีอยู่แล้วด้านบน
#                                 (admin client เขียนผ่าน RLS service_role).
# ⚠️ ใส่ค่าจริงใน `.env.local` เท่านั้น — ห้าม commit token ลง repo /
#    ห้ามส่ง token ผ่านแชท / ห้าม hardcode ลงไฟล์โค้ด.
# Webhook URL ที่ตั้งใน LINE Developers Console:
#   https://<your-domain>/api/webhooks/line   (ดู docs/runbook/line-webhook-setup.md)
LINE_CHANNEL_ID=<from-line-developer-console>
LINE_CHANNEL_SECRET=<from-line-developer-console>
LINE_CHANNEL_ACCESS_TOKEN=<long-lived-token-from-line-console>
NEXT_PUBLIC_LIFF_ID=<liff-id-from-line-console>

# P1-24 — staff-group LINE-OA alerts (replaces legacy dead LINE Notify staff ping).
# When set + LINE_PUSH_BYPASS=false, customer ฝากโอน/ฝากชำระ creates ping this
# group so ops verify promptly (lib/notifications/staff-group.ts → notifyStaffGroup).
# HOW TO GET IT: add the @pacred OA bot to the internal staff LINE group, then read
# the groupId (Cxxxxxxxx…) from the webhook event on join. Unset → wired no-op.
LINE_STAFF_GROUP_ID=<staff-line-group-id-Cxxxx>  # OPTIONAL — unset = no-op


# ── 🟡 LINE LIFF — customer→profile linkage (D-1-LIFF) ───────────
# https://developers.line.biz → your Messaging API channel → LIFF tab → Add
#   Endpoint URL: https://<your-domain>/liff/link  (use ngrok in dev)
#   Size:         Compact
#   Scope:        profile + openid
#   BOT link feature: On (Aggressive)  ← so add-friend nudge appears
# Without this: every "เชื่อม LINE" CTA fails to init LIFF
#   → customer can't link → LINE push to customer is silent no-op forever
NEXT_PUBLIC_LIFF_ID=<liff-app-id-from-line-console>


# ── 🟡 EMAIL FALLBACK — Resend ───────────────────────────────────
# https://resend.com → API Keys
# Used when LINE push fails or user prefers email
RESEND_API_KEY=<re_xxx>
RESEND_FROM=Pacred <noreply@pacred.co>


# ── 🟡 CRON SECURITY ─────────────────────────────────────────────
# Generate: openssl rand -hex 32
# Vercel cron sends x-vercel-cron header, we also check Bearer ${CRON_SECRET}
CRON_SECRET=<random-hex-string>

# ── 🟢 AUTO-PROVIDED BY VERCEL (no value to set; documented for env audit) ──
# Vercel injects these at build/runtime — they appear in process.env on prod.
# Listed here so scripts/env-audit.mjs doesn't flag them as "used-not-declared".
# (Don't set values; leave blank.)
VERCEL_GIT_COMMIT_SHA=


# ── 🟡 YUAN RATE (optional fallback) ─────────────────────────────
# If unset, code reads from settings table (preferred)
# This is only a hard-coded fallback for dev when DB is empty
NEXT_PUBLIC_YUAN_RATE=5.00


# ── ⚪ LINE LOGIN (optional — not yet implemented) ───────────────
# When LINE OAuth is built, set these from LINE Developers Console (different
# channel from Messaging API above — use a "LINE Login" channel)
# LINE_LOGIN_CLIENT_ID=
# LINE_LOGIN_CLIENT_SECRET=


# ── 🟡 LINE NOTIFY (per-user push — G5 legacy port) ─────────────
# ⚠️ LINE Notify is EOL April 2025 (announced by LINE Corp). This is a
#    TRANSITION implementation: keeps the migrated PCS customers' existing
#    "Connect LINE Notify" buttons functional during cut-over. Long-term:
#    migrate to LINE Messaging API per-user (see lib/notifications/index.ts).
#
# Get credentials from: https://notify-bot.line.me → My Services → New service
#   Service URL:          https://pacred.co.th
#   Callback URL:         https://pacred.co.th/api/linenotify/callback
#
# When LINE_NOTIFY_CLIENT_ID is unset: the OAuth authorize URL builder
# throws, and the connect button is hidden by UI gating (added later).
# pushToLineNotify() respects LINE_PUSH_BYPASS — when true, console.log only.
LINE_NOTIFY_CLIENT_ID=
LINE_NOTIFY_CLIENT_SECRET=
LINE_NOTIFY_CALLBACK_URL=https://pacred.co.th/api/linenotify/callback


# ── ⚪ CARRIER APIS — JMF + CargoThai (legacy PHP integrations) ──
# JMFCARGO sister-cargo sync — token = concatenation of legacy Tiso key+secret
# Used in pcs-admin/api/update-forwarder/JMFCARGO/{GET,PUT}/. Pacred port = future task
# JMF_CARGO_TOKEN=
# JMF_CARGO_BASE_URL=https://jmfcargo.com/jmf-cargo/jmf-admin/api
#
# CargoThai TTP container API (active legacy) — query-string _token only
# CARGOTHAI_TTP_TOKEN=a807f4fe8c5bbf0010f6b3abfc52b4
# CARGOTHAI_CN_TOKEN=aea07c4d3d1709313c4bb2d07a4702
# CARGOTHAI_BASE_URL=https://cargothai.tech/api/service


# ── 🟡 hCAPTCHA — invisible bot protection (D-13) ───────────────
# https://www.hcaptcha.com → Sites → New Site → Type "invisible"
# Site key is public (inlined into client bundle); secret is server-only.
#
# ⚠️  Fail-mode: lib/hcaptcha.ts degrades **OPEN** when HCAPTCHA_SECRET_KEY is
#     unset — verifyHcaptcha() returns {success:true} regardless of env. In
#     production a `logger.warn` is emitted ("HCAPTCHA_SECRET_KEY unset in
#     production — bot protection DEGRADED"). This is intentional per
#     docs/env.md §12: signup is still gated by phone OTP + IP rate-limiting,
#     so hard-blocking real signups to stop hypothetical bots is the wrong
#     trade during the launch push.
#
# Recommendation: set BOTH keys in production to restore full verification
# (zero code change). Resolves gap-integrations G-3 documentation contradiction.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=


# ── 🟡 RATE LIMITING — Upstash Redis (D-12) ─────────────────────
# https://console.upstash.com → create Redis DB → REST API tab
# Both vars optional — when unset, lib/rate-limit.ts falls back to
# an in-memory Map (dev only — multi-instance prod will leak quota
# because each Vercel function instance has its own memory).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ── 🟡 MOMO JMF — Thailand warehouse cargo container partner ────
# JWT issued by MOMO dev (request via LINE / partner channel).
# Used by lib/integrations/momo-jmf/* (when ก๊อต wires the spec) to
# consume container-status API + retrieve closed-container manifests.
# See docs/integrations/momo-jmf.md for endpoint inventory.
# Without this: cargo container tracking degrades to manual entry by
# warehouse staff (not silent — admin sees a "MOMO sync paused" banner).
MOMO_JMF_TOKEN=
# MOMO_JMF_BASE_URL=https://<momo-tbd>/api

# MOMO Cargo — LCL sack tracking API (D1 Gap #6).
# Separate service from MOMO_JMF above: different host + different bearer.
# Used by /admin/momo-lcl + lib/integrations/momo-lcl/check-sack.ts.
# Legacy curl (check-tracks.php):
#   GET https://api.momocargo.com:8080/api/sack/get/info/{sack}
#   Authorization: Bearer <JWT issued by MOMO ops>
# Without this: the admin lookup returns "momo_not_configured" — page renders
# but submitting shows a "ระบบยังไม่ได้ตั้งค่า MOMO API token" banner.
# MOMO_CARGO_SACK_BASE_URL=https://api.momocargo.com:8080
MOMO_CARGO_SACK_TOKEN=

# MOMO sync — status-propagation gate (ภูม decision #6, 2026-05-30).
# When "true", the MOMO sync pipeline (lib/integrations/momo-isolated/propagate.ts)
# advances tb_forwarder.fstatus on container_closed events (e.g. 3→4 ถึงไทย) +
# fires the customer SMS/LINE notification on that transition. Default OFF —
# leave unset until the notify wiring is verified on prod (cron auto-commit risk).
# MOMO_SYNC_PROPAGATE_STATUS=true


# ── 🟡 ANALYTICS — Google Tag Manager (L-22) ────────────────────
# https://tagmanager.google.com → New Container → Web
# GTM container loads GA4 + future tags (Meta Pixel, TikTok Pixel, etc.)
# without code redeploy. When unset, lib/analytics.ts logs to console in dev
# and is silent in prod. NEXT_PUBLIC_ prefix is required to inline into client bundle.
NEXT_PUBLIC_GTM_ID=


# ── 🟡 HEATMAP — Microsoft Clarity (L-23) ───────────────────────
# https://clarity.microsoft.com → New Project → copy 10-char project ID
# Free, no quota. Provides heatmap, click recording, scroll tracking,
# session replay. When unset, ClarityScript renders nothing.
# Custom tagging via clarityTag() / clarityEvent() helpers in lib/analytics.ts.
NEXT_PUBLIC_CLARITY_ID=


# ── 🟢 PAID-ADS TRACKING — embedded on every page (owner directive 2026-05-20) ──
# Every ID is HARDCODED as a default in components/analytics/<X>Script — these
# env vars are optional overrides only (dev/staging swap). Leaving them blank is
# fine in prod; the hardcoded fallback fires. Memory: tracking_codes_embed_rule.md.

# Google Ads conversion / remarketing tag — Pacred's account.
# Hardcoded fallback: AW-17941254120 (in google-ads-script.tsx).
NEXT_PUBLIC_GOOGLE_ADS_ID=

# GA4 measurement — analytics.google.com → Admin → Data Streams → Web stream.
# Hardcoded fallback: G-62J8PEVJLZ (in google-analytics-script.tsx).
NEXT_PUBLIC_GA4_ID=

# Google Tag (consolidated gtag) — the new GT-… ID that bundles GA4/Ads/etc.
# Hardcoded fallback: GT-KFHGBVK9 (in google-analytics-script.tsx).
NEXT_PUBLIC_GOOGLE_TAG_ID=

# Meta (Facebook) Pixel — business.facebook.com → Events Manager → Pixel ID.
# Hardcoded fallback: 27209891118650099 (in facebook-pixel-script.tsx).
NEXT_PUBLIC_FB_PIXEL_ID=


# ── 🟡 SENTRY — error tracking (D-11) ───────────────────────────
# https://sentry.io → Settings → Projects → <project> → Client Keys (DSN)
# All vars optional — when SENTRY_DSN is unset, Sentry SDK is no-op.
# Server + client need separate DSN env vars (NEXT_PUBLIC_ for browser).
# Same DSN value, but Next 16 requires NEXT_PUBLIC_ prefix to inline into client bundle.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ENV=production               # override of NODE_ENV for the env tag
# NEXT_PUBLIC_SENTRY_ENV=production
# Source map upload (optional — improves prod stack traces)
# Get auth token from https://sentry.io → Settings → Auth Tokens (org-level, project:write scope)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=pacred
# SENTRY_PROJECT=pacred-web
# IO-1 observability — Sentry → Pacred incident webhook (app/api/observability/sentry-webhook).
# The shared secret Sentry signs the webhook payload with (Sentry-Hook-Signature, HMAC-SHA256).
# Set it in the Sentry integration's webhook config + here. Unset → the webhook route 503s
# (the global-error boundary + the /api/observability/incident sink work without it).
SENTRY_WEBHOOK_SECRET=


# ── 🟢 SUPABASE S3 PROTOCOL (storage — added 2026-05-24) ──
# https://app.supabase.com → Project Settings → Storage → S3 Connection
# Used for direct S3-protocol uploads (avoiding Storage API overhead for large
# batches — see ภูม's 2026-05-24 customer-image migration). The legacy
# pcsracgo/public/member image folders + storage files are uploaded here in
# production. New buckets created via this protocol.
# ⚠️ Server-only (do NOT prefix NEXT_PUBLIC_).
SUPABASE_S3_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-southeast-1
SUPABASE_S3_ACCESS_KEY_ID=<key-id>
SUPABASE_S3_SECRET_ACCESS_KEY=<secret>


# ════════════════════════════════════════════════════════════
# Migration / Backfill scripts (CLI-only — never used at runtime)
# ════════════════════════════════════════════════════════════
# Supabase prod direct-DB password — passed inline at script invocation:
#   PG_PASSWORD='<prod-db-pass>' node scripts/apply-pilot-migration.mjs
# Read from Dashboard → Project Settings → Database → Connection string.
# NEVER commit a real value. Declared here so audit:env recognises it.
PG_PASSWORD=
# Dry-run guard for the orphan backfill (scripts/backfill-orphan-tb-users.mjs):
# unset = dry-run (no writes) · APPLY=true = commit. CLI-only.
APPLY=


# ════════════════════════════════════════════════════════════
# MOMO Admin Sync (ปอน 2026-05-28 ดึก · isolated parallel integration)
# ════════════════════════════════════════════════════════════
# Powers /admin/api-forwarder-momo/sync — writes to momo_* isolated tables
# (NO legacy touch). Without these the admin sync page renders but the
# sync button returns 'not_configured'. Real-API verified live by ปอน.
MOMO_API_BASE_URL=
MOMO_API_TOKEN=
# Auth header name (default 'Authorization') + prefix (default 'Bearer ')
MOMO_API_AUTH_HEADER=Authorization
MOMO_API_AUTH_PREFIX=Bearer
# Wave 30.5 — gate for the /api/cron/momo-sync auto-commit step. Default OFF
# ('false'/unset) = cron is PULL-ONLY (fresh momo_* data every 5 min; admin
# still clicks /review to commit each row → tb_forwarder). Set to 'true' to
# let cron auto-commit HIGH-CONFIDENCE rows (valid userid match) straight to
# tb_forwarder. Money-path conservatism: a wrong auto-commit bills the wrong
# customer, so opt IN only after eyeballing a sample of would-be commits.
# See lib/admin/auto-commit-momo.ts + app/api/cron/momo-sync/route.ts.
MOMO_CRON_AUTOCOMMIT=false


# ════════════════════════════════════════════════════════════
# DBD juristic-person lookup (เดฟ 2026-05-30 · /admin/juristic-check)
# ════════════════════════════════════════════════════════════
# Powers the "ตรวจสอบกับ DBD" compare panel (faithful to legacy
# check-juristic/compare.php). A URL template — `{taxId}` is substituted,
# or (no placeholder) the 13-digit id is appended.
#   - UNSET (default) = manual-check mode: NO external call, the UI links to
#     dbd.go.th DataWarehouse and the admin verifies by eye. Safe default —
#     a customer's tax id is never sent to a third party unless wired here.
#   - Legacy "borrowed" scraper endpoint (per docs/runbook/pcs-scrub-plan.md —
#     confirm it is still live + acceptable before enabling in prod):
#       DBD_LOOKUP_URL=http://hexvapes.com/check-juristic-person/?juristic_id={taxId}
#   Expects JSON { status:200, data:[{ OrganizationJuristicNameTH, ... }] }.
DBD_LOOKUP_URL=


# ════════════════════════════════════════════════════════════
# CI / tsc wrapper (script-only — never used at runtime)
# ════════════════════════════════════════════════════════════
# Used by scripts/tsc-check.mjs to bump Node heap for the OOM-prone
# tsc --noEmit invocation. Default 8 GB. CI sets via job env.
NODE_OPTIONS=


# ════════════════════════════════════════════════════════════
# Vercel-injected (DO NOT SET MANUALLY)
# ════════════════════════════════════════════════════════════
# Vercel automatically injects these into every deployment env.
# Listed here so audit:all (env-audit.mjs) recognises them as known.
# Locally undefined → consumers fall back to "dev" / static placeholder.
#
# Used by /status page to surface the current build commit for support
# traceability ("which build are you running?").
# VERCEL_GIT_COMMIT_SHA=
