# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev-restart.log
dev*.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code session worktrees (separate git checkouts, not source)
.claude/worktrees/
.claude/settings.local.json

# Backfill 06 progress files (contain target paths only · no secrets)
# Keep gitignored to avoid leaking the backfill state across machines.
scripts/backfill/.progress/

.claude/scheduled_tasks.lock
.pcs-sync-token-*.txt

# customer-code swap backups (PII — never commit)
*-backup.json
