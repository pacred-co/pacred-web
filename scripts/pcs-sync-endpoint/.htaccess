# Pacred sync endpoint security hardening.
# Upload to: /public_html/api/.htaccess
#
# - Only allow GET (we only read).
# - Hide PHP source if something glitches.
# - Block common path-traversal probes.

<Files "pacred-sync.php">
    # Allow only GET + HEAD
    <LimitExcept GET HEAD>
        Require all denied
    </LimitExcept>
</Files>

# Force PHP execution (Apache mod_php / mod_proxy_fcgi compatible).
<FilesMatch "\.php$">
    SetHandler application/x-httpd-php
</FilesMatch>

# Block direct access to .inc, .bak, dotfiles.
<FilesMatch "(^\.|\.(inc|bak|orig|swp)$)">
    Require all denied
</FilesMatch>
